(defcfg
process-unmapped-keys yes
concurrent-tap-hold yes
)

(defsrc
q w e r t y u i o p
a s d f g h j k l ;
z x c v b n m , . /
lalt spc ralt
)

(defvar
tap-time 175
hold-time 175

left-hand-keys (
q w e r t
a s d f g
z x c v b
)

right-hand-keys (
y u i o p
h j k l ;
n m , . /
)
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Home row mods (chord-safe)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
(defalias
a (tap-hold-release-keys $tap-time $hold-time a lmet $right-hand-keys)
s (tap-hold-release-keys $tap-time $hold-time s lalt $right-hand-keys)
d (tap-hold-release-keys $tap-time $hold-time d lctl $right-hand-keys)
f (tap-hold-release-keys $tap-time $hold-time f lsft $right-hand-keys)

j (tap-hold-release-keys $tap-time $hold-time j rsft $left-hand-keys)
k (tap-hold-release-keys $tap-time $hold-time k rctl $left-hand-keys)
l (tap-hold-release-keys $tap-time $hold-time l ralt $left-hand-keys)
; (tap-hold-release-keys $tap-time $hold-time ; rmet $left-hand-keys)
space (tap-hold $tap-time $hold-time spc lsft)
lalt (tap-hold $tap-time $hold-time spc (layer-while-held brackets))
ralt (tap-hold $tap-time $hold-time enter (layer-while-held umlaute))
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Base layer
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deflayer base
q w e r t y u i o p
@a @s @d @f g h @j @k @l @;
z x c v b n m , . /
@lalt @space @ralt
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Navigation layer
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deflayer nav
_ _ _ _ _ home pgdn pgup end _
_ _ _ _ _ left down up right _
_ _ _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Brackets
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defalias
rparen S-0
lparen S-9
{ S-[
} S-]
- S--
= S-=
' S-'
\ S-\
` S-`
)

(defalias
1 S-1
2 S-2
3 S-3
4 S-4
5 S-5
6 S-6
7 S-7
8 S-8
9 S-9
0 S-0
)
(deflayer brackets
@` @5 @\ @' @6 @= @rparen ] @} @-
`  @2  \  ' @4  = @lparen [ @{  -
_ _ _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Numbers
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deflayer lnum
6 7 8 9 0 _ _ _ _ _
1 2 3 4 5 _ _ _ _ _
_ _ _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Shifted Numbers (Symbols)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;


(deflayer lnum-shift
@6 @7 @8 @9 @0 _ _ _ _ _
@1 @2 @3 @4 @5 _ _ _ _ _
_ _ _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Function layer
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deflayer lfun
f6 f7 f8 f9 f10 _ _ _ _ _
f1 f2 f3 f4 f5 _ _ _ _ _
f11 f12 _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Umlauts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defalias
ß (unicode ß)
ä (unicode ä)
ü (unicode ü)
ö (unicode ö)
)

(deflayer umlaute
6 7 8 9 0 _  _  _  _  _ 
1 2 3 4 5 _ @ß @ä @ü @ö
_ _ _ _ _ _ _ _ _ _
_ _ _
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Chords
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
(defvar
chord-time 40
)

(defchordsv2

;; editing
(z ;) esc                $chord-time all-released ()
(f j) tab                $chord-time all-released ()
(a ;) ent                $chord-time all-released ()
(d h) bspc               $chord-time all-released ()
(d l) del                $chord-time all-released ()

;; layer access
(a s) (layer-while-held umlaute) $chord-time all-released ()
(d f) (layer-while-held brackets) $chord-time all-released ()
(s d) (layer-while-held nav) $chord-time all-released ()
(j k) (layer-while-held lnum) $chord-time all-released ()
(k l) (layer-while-held lnum-shift) $chord-time all-released ()
(l ;) (layer-while-held lfun) $chord-time all-released ()

)
